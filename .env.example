# ClinicalMatch — project environment (copy to .env and fill in).
# .env is git-ignored and never committed. `docker compose` reads this file for
# ${VAR} substitution, and the backend service loads it via env_file.

# --- Ingress / Traefik -------------------------------------------------------

# Public subdomain the app is served from (no scheme), e.g. czajka.aibr.cz.
# Used in the Traefik routing rules and must have a DNS A/AAAA record pointing
# at this server.
DOMAIN=

# Email Let's Encrypt uses for certificate notices, e.g. o.czajka.2004@gmail.com
ACME_EMAIL=

# --- Backend (consumed inside the backend container) -------------------------

# Port the backend listens on inside the container. Default 3001. If you change
# it, update the backend loadbalancer.server.port label in docker-compose.yml.
PORT=

# Browser origin allowed by CORS — the public https URL the app is served from
# (e.g. https://czajka.aibr.cz). Frontend and backend are same-origin behind
# Traefik, so this is effectively a safety belt.
CORS_ORIGIN=

# Runtime mode: production for the deployed stack.
NODE_ENV=

# SQLite file path inside the container. Default data/clinicalmatch.sqlite,
# backed by the `backend-data` volume. Leave as default unless you know why.
DB_PATH=

# CTIS (EU Clinical Trials Information System) importer — backend only, never
# called from the browser. All optional; sensible defaults apply when blank.
# CTIS_API_URL default: https://euclinicaltrials.eu/ctis-public-api
CTIS_API_URL=
CTIS_TIMEOUT_MS=          # per-request timeout ms (default 20000)
IMPORT_LIMIT=            # trials per disease area (default 8)
IMPORT_BATCH_SIZE=       # CTIS search page size (default 20)
IMPORT_RETRY_COUNT=      # retries per request (default 2)
IMPORT_DISEASES=         # comma list of disease areas (default: all ~40 areas)
IMPORT_STATUS=           # comma list of statuses to keep (default all)
IMPORT_COUNTRIES=      # comma list of countries to keep (default all)
SYNC_INTERVAL_HOURS=     # cadence hint for a scheduled sync (default 24)

# OpenAI / LLM provider — powers the AI smart features through the backend's
# shared LLM abstraction layer (src/ai/llm.ts), never the browser. When
# OPENAI_API_KEY is blank the AI endpoints return a calm fallback instead of
# crashing. All others optional; defaults apply when blank.
OPENAI_API_KEY=
OPENAI_BASE_URL=         # default https://api.openai.com/v1
OPENAI_MODEL=            # default gpt-4o-mini
OPENAI_TEMPERATURE=      # default 0.2
OPENAI_MAX_TOKENS=       # default 800
OPENAI_EMBEDDING_MODEL=  # default text-embedding-3-small (used by the RAG feature)

# --- Frontend build (host side) ----------------------------------------------

# Public backend URL baked into the frontend bundle at BUILD time. Behind
# Traefik the API lives under the /api path on the same host, so this is
# https://<DOMAIN>/api (e.g. https://czajka.aibr.cz/api). Reachable from the
# browser; NOT the internal `backend` service name.
VITE_API_URL=
