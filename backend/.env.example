PORT=
CORS_ORIGIN=
NODE_ENV=
DB_PATH=
# CTIS (EU Clinical Trials Information System) importer — backend only.
# All optional; sensible defaults apply when blank.
CTIS_API_URL=
CTIS_TIMEOUT_MS=
IMPORT_LIMIT=
IMPORT_BATCH_SIZE=
IMPORT_RETRY_COUNT=
IMPORT_DISEASES=
IMPORT_STATUS=
IMPORT_COUNTRIES=
SYNC_INTERVAL_HOURS=
# OpenAI / LLM provider — powers the AI smart features (src/ai/llm.ts).
# When OPENAI_API_KEY is blank the AI endpoints return a calm fallback instead
# of crashing. All others are optional; defaults apply when blank.
OPENAI_API_KEY=
OPENAI_BASE_URL=          # default https://api.openai.com/v1
OPENAI_MODEL=            # default gpt-4o-mini
OPENAI_TEMPERATURE=      # default 0.2
OPENAI_MAX_TOKENS=       # default 800
OPENAI_EMBEDDING_MODEL=  # default text-embedding-3-small (used by the RAG feature)
